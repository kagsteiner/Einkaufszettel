# Runtime mode: development, test, or production.
APP_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:3000
DATABASE_PATH=data/einkaufszettel.db

# 32 random bytes encoded as Base64. Required when personal API keys are saved.
APP_ENCRYPTION_KEY=

# Development fallback for OpenAI-powered actions. Ignored in production.
OPENAI_API_KEY=
